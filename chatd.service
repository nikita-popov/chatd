[Unit]
Description=simple chat backend
After=network.target

[Service]
Type=simple
User=chatd
WorkingDirectory=/opt/chatd
ExecStart=/opt/chatd/venv/bin/gunicorn \
    --bind 0.0.0.0:5001 \
    --worker-class gevent \
    --workers 1 \
    --timeout 360 \
    --keep-alive 5 \
    chatd:app
Restart=on-failure
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
