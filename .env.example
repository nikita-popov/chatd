# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.
#
# chatd reads these variables at startup.  You can also set them as
# Environment= directives in the systemd unit instead of using a file.

# ── Ollama ────────────────────────────────────────────────────────────────────────
OLLAMA_API=http://127.0.0.1:11434

# ── MCP servers ───────────────────────────────────────────────────────────────────
# Register any number of MCP servers with CHATD_MCP_<NAME>=<shell command>.
# chatd discovers all CHATD_MCP_* variables automatically at startup.
#
# Replace /opt/chatd/venv/bin/python with the actual path to your venv Python.

CHATD_MCP_MONITOR=/opt/chatd/venv/bin/python /opt/chatd/mcp-monitor.py
CHATD_MCP_ALERTS=/opt/chatd/venv/bin/python /opt/chatd/mcp-alerts.py
CHATD_MCP_NOTES=/opt/chatd/venv/bin/python /opt/chatd/mcp-notes.py
CHATD_MCP_MEMPALACE=/opt/chatd/venv/bin/python -m mempalace.mcp_server

# ── Notes (Memos) ───────────────────────────────────────────────────────────────────
MEMOS_URL=http://localhost:5230
MEMOS_TOKEN=

# ── Monitoring ────────────────────────────────────────────────────────────────────
ALERTMANAGER_URL=http://localhost:9093
VICTORIA_URL=http://localhost:8428

# ── MemPalace ──────────────────────────────────────────────────────────────────────
# Path to the palace directory (wings/rooms hierarchy).
MEMPALACE_PALACE_PATH=/var/lib/mempalace

# Path to knowledge_graph.sqlite3.  Set this explicitly when the KG file
# lives in a different directory than the palace.
# Default: ~/.mempalace/knowledge_graph.sqlite3
MEMPALACE_KG_PATH=/opt/chatd/.mempalace/knowledge_graph.sqlite3

# Comma-separated list of mempalace tools to expose to the model.
# Uncomment and edit to restrict or extend the default set.
# CHATD_MEMPALACE_TOOLS=mempalace_status,mempalace_search,mempalace_add_drawer,mempalace_kg_query,mempalace_kg_add

# ── Sampling (optional) ───────────────────────────────────────────────────────────────
# CHATD_THINKING=false
# CHATD_TEMPERATURE=0.3
# CHATD_TOP_P=0.9
# CHATD_TOP_K=40
# CHATD_REPEAT_PENALTY=1.05
# CHATD_NUM_CTX=8192
# CHATD_NUM_PREDICT=768
