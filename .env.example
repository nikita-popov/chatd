# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.
#
# chatd reads these variables at startup.  You can also set them as
# Environment= directives in the systemd unit instead of using a file.
#
# Effective memory stack in chatd:
#   L0   - mempalace - model identity.txt                    - Always loaded
#   L0.5 - chatd     - per-chat summary + global summary     - Always loaded
#   L1   - mempalace - Essential Story (wake-up context)     - Always loaded
#   L1.5 - chatd     - KG recall + RAG sidecar               - Always loaded
#   L2   - mempalace - Room Recall (filtered retrieval)      - When topic comes up
#   L3   - mempalace - Deep Search (full semantic query)     - When explicitly asked

# ── Ollama ────────────────────────────────────────────────────────────────────────
OLLAMA_API=http://127.0.0.1:11434

# ── MCP servers ───────────────────────────────────────────────────────────────────
# Register any number of MCP servers with CHATD_MCP_<NAME>=<shell command>.
# chatd discovers all CHATD_MCP_* variables automatically at startup.
#
# Replace /path/to/venv/bin/python with the actual path to your venv Python.

CHATD_MCP_MEMPALACE=/path/to/venv/bin/python -m mempalace.mcp_server

# ── MemPalace ──────────────────────────────────────────────────────────────────────
# Path to the palace directory (wings/rooms hierarchy).
MEMPALACE_PALACE_PATH=/var/lib/mempalace

# Path to knowledge_graph.sqlite3.  Set this explicitly when the KG file
# lives in a different directory than the palace.
# Default: ~/.mempalace/knowledge_graph.sqlite3
# MEMPALACE_KG_PATH=/path/to/.mempalace/knowledge_graph.sqlite3

# Uncomment and change to true to enable filtering of the list of tools available to the model.
# CHATD_TOOLS_FILTER=false

# Comma-separated list of tools to expose to the model.
# Uncomment and edit to restrict or extend the default set.
# CHATD_TOOLS_ALLOWED=mempalace_status,mempalace_search,mempalace_add_drawer,mempalace_kg_query,mempalace_kg_add

# Enable overwriting tool descriptions with data from tool_descriptions.ini
# CHATD_TOOL_OVERRIDE=false

# Data for rewriting tool descriptions.
# CHATD_TOOL_DESCRIPTIONS=/etc/chatd/tool_descriptions.ini

# ── Sampling (optional) ───────────────────────────────────────────────────────────────
# CHATD_THINKING=false
# CHATD_TEMPERATURE=0.3
# CHATD_TOP_P=0.9
# CHATD_TOP_K=40
# CHATD_REPEAT_PENALTY=1.05
# CHATD_NUM_CTX=8192
# CHATD_NUM_PREDICT=768

# ── Session / summaries ─────────────────────────────────────────────────────────────
# Directory where per-chat session JSON files are stored.
# CHATD_SESSION_DIR=~/.local/share/chatd/sessions

# Global compressed summary path (L0.5 global part).
# CHATD_GLOBAL_SUMMARY_PATH=~/.local/share/chatd/global_summary.txt

# Ollama model used for summary compression.
# CHATD_SUMMARY_MODEL=qwen2.5:1.5b

# Number of new Q/A turns to accumulate before triggering compression.
# CHATD_COMPRESS_EVERY=5

# ── OpenRouter (optional cloud backend) ───────────────────────────────────────────
# Prefix model names with "or:" to route them to OpenRouter instead of Ollama.
# Example: model=or:mistralai/mistral-7b-instruct:free
#
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_PREFIX=or:

# ── External RAG store (L1.5) ─────────────────────────────────────────────────────
# chatd-owned SQLite store, completely separate from mempalace.
# Conversation turns are embedded and retrieved by cosine similarity.
#
# Before enabling, pull the embed model:
#   ollama pull nomic-embed-text
#
# CHATD_RAG_DB_PATH=~/.local/share/chatd/rag.sqlite3
#
# Embed backend: "ollama" (default) or "onnx" (local ONNX encoder).
# CHATD_RAG_BACKEND=ollama
#
# Model name passed to the embed backend.
# CHATD_RAG_EMBED_MODEL=nomic-embed-text
#
# Vector dimensionality — must match the embed model output.
# nomic-embed-text → 768, mxbai-embed-large → 1024
# CHATD_RAG_EMBED_DIM=768
#
# Number of chunks to return per retrieval.
# CHATD_RAG_TOP_K=4
#
# Maximum characters per indexed chunk (user+assistant combined).
# CHATD_RAG_MAX_CHARS_PER_CHUNK=4000
#
# Minimum cosine similarity score to include a chunk (0 = identical, 1 = orthogonal).
# Lower values return more (noisier) results.
# CHATD_RAG_MIN_SCORE=0.25
